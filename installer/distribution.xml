<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>PremImageGen</title>
    <organization>com.imagegen</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="false" rootVolumeOnly="true"/>
    <welcome    file="welcome.html"    mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    <pkg-ref id="com.imagegen.prem.pkg"/>
    <choices-outline>
        <line choice="default">
            <line choice="com.imagegen.prem.pkg"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.imagegen.prem.pkg" visible="false">
        <pkg-ref id="com.imagegen.prem.pkg"/>
    </choice>
    <pkg-ref id="com.imagegen.prem.pkg"
             version="1.0.0"
             onConclusion="none">_PremImageGen-component.pkg</pkg-ref>
</installer-gui-script>
