#!/usr/bin/env bash
# Postinstall script — runs as root after pkg payload is laid down.

export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:$PATH"

# ── Detect the actual logged-in user (not root) ───────────────────────────────
CURRENT_USER=$(stat -f "%Su" /dev/console 2>/dev/null)
if [ -z "$CURRENT_USER" ] || [ "$CURRENT_USER" = "root" ]; then
  CURRENT_USER=$(scutil <<< "show State:/Users/ConsoleUser" 2>/dev/null | awk '/Name :/ { print $3 }')
fi
if [ -z "$CURRENT_USER" ] || [ "$CURRENT_USER" = "root" ]; then
  echo "ERROR: Could not detect logged-in user. Helper must be installed manually."
  exit 0
fi

USER_HOME=$(eval echo "~$CURRENT_USER")
HELPER_SRC="/Library/Application Support/AEImageGen/helper-src"
HELPER_DEST="$USER_HOME/Library/Application Support/AEImageGen/helper"
LOG_DIR="$USER_HOME/Library/Logs/AEImageGen"

echo "Installing for user: $CURRENT_USER"

# ── Install or update helper ──────────────────────────────────────────────────
if [ -d "$HELPER_DEST/node_modules" ]; then
  # Existing AE plugin install — sync source files only
  echo "Existing helper found — syncing source files..."
  rsync -a "$HELPER_SRC/src/" "$HELPER_DEST/src/"
else
  # Fresh install — copy everything including node_modules
  echo "Installing helper..."
  mkdir -p "$HELPER_DEST"
  rsync -a "$HELPER_SRC/" "$HELPER_DEST/"
fi

chown -R "$CURRENT_USER" "$HELPER_DEST"

# ── Create log directory ──────────────────────────────────────────────────────
mkdir -p "$LOG_DIR"
chown -R "$CURRENT_USER" "$LOG_DIR"

# ── Enable unsigned CEP extensions for the user ───────────────────────────────
sudo -u "$CURRENT_USER" defaults write com.adobe.CSXS.11 PlayerDebugMode 1 2>/dev/null || true
sudo -u "$CURRENT_USER" defaults write com.adobe.CSXS.12 PlayerDebugMode 1 2>/dev/null || true
sudo -u "$CURRENT_USER" defaults write com.adobe.CSXS.13 PlayerDebugMode 1 2>/dev/null || true
echo "PlayerDebugMode set ... OK"

# ── Remove staging helper source ──────────────────────────────────────────────
rm -rf "$HELPER_SRC"

echo "PremImageGen postinstall complete."
exit 0
