{
  "name": "ae-image-gen-helper",
  "version": "1.0.0",
  "description": "Local helper service for AE Image Gen panel",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "build": "pkg src/server.js --target node20-macos-x64,node20-win-x64 --output ../dist/AEImageGenHelper"
  },
  "dependencies": {
    "@fal-ai/client": "^1.3.0",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
