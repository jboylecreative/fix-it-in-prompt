<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest
    ExtensionBundleId="com.imagegen.prem"
    ExtensionBundleName="Fix It In Prompt"
    ExtensionBundleVersion="1.0.0"
    Version="7.0">

  <ExtensionList>
    <Extension Id="com.imagegen.prem.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="PPRO" Version="[22.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="12.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.imagegen.prem.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/premiere.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Fix It In Prompt</Menu>
          <Geometry>
            <Size>
              <Width>420</Width>
              <Height>680</Height>
            </Size>
            <MinSize>
              <Width>300</Width>
              <Height>400</Height>
            </MinSize>
          </Geometry>
          <Icons/>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
